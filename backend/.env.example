# ===== Servidor =====
PORT=4000
NODE_ENV=development
# Coma-separado. Para desarrollo movil usa * o agrega la IP de tu PC.
CORS_ORIGIN=*

# ===== Base de datos PostgreSQL =====
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=bilwi_cargo

# ===== Seguridad / JWT =====
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=30d

# ===== Reglas de negocio =====
# Radio (km) para buscar conductores cercanos
NEARBY_RADIUS_KM=8
# Comision de la plataforma (0.15 = 15%)
PLATFORM_COMMISSION=0.15
